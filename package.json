{
  "name": "oh-my-humanizer-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Discord listener for oh-my-humanizer autonomous bot",
  "type": "module",
  "scripts": {
    "listener": "node scripts/discord-listener.js",
    "listener:start": "systemctl --user start oh-my-humanizer-listener",
    "listener:stop": "systemctl --user stop oh-my-humanizer-listener",
    "listener:status": "systemctl --user status oh-my-humanizer-listener",
    "listener:logs": "journalctl --user -u oh-my-humanizer-listener -f"
  },
  "dependencies": {
    "discord.js": "^14.18.0"
  }
}
