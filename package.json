{
  "name": "patina-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Discord listener for patina autonomous bot",
  "type": "module",
  "scripts": {
    "listener": "node scripts/discord-listener.js",
    "listener:start": "systemctl --user start patina-listener",
    "listener:stop": "systemctl --user stop patina-listener",
    "listener:status": "systemctl --user status patina-listener",
    "listener:logs": "journalctl --user -u patina-listener -f"
  },
  "dependencies": {
    "discord.js": "^14.18.0"
  }
}
