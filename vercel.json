{
  "cleanUrls": true,
  "trailingSlash": false,
  "github": {
    "silent": true
  },
  "functions": {
    "api/rewrite.js": {
      "includeFiles": "{patterns/**,profiles/**,core/**,lexicon/**,.patina.default.yaml}"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/playground"
    },
    {
      "source": "/app.js",
      "destination": "/playground/app.js"
    },
    {
      "source": "/i18n.js",
      "destination": "/playground/i18n.js"
    },
    {
      "source": "/analysis-dispatch.js",
      "destination": "/playground/analysis-dispatch.js"
    },
    {
      "source": "/analyzer-worker.js",
      "destination": "/playground/analyzer-worker.js"
    },
    {
      "source": "/analytics.js",
      "destination": "/playground/analytics.js"
    },
    {
      "source": "/analyzer.js",
      "destination": "/playground/analyzer.js"
    },
    {
      "source": "/rewrite-client.js",
      "destination": "/playground/rewrite-client.js"
    },
    {
      "source": "/chat-ui.js",
      "destination": "/playground/chat-ui.js"
    },
    {
      "source": "/rewrite-mode.js",
      "destination": "/playground/rewrite-mode.js"
    },
    {
      "source": "/rewrite.css",
      "destination": "/playground/rewrite.css"
    },
    {
      "source": "/styles.css",
      "destination": "/playground/styles.css"
    },
    {
      "source": "/data/:path*",
      "destination": "/playground/data/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "clipboard-write=(self), camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
