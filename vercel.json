{
  "cleanUrls": true,
  "trailingSlash": false,
  "github": {
    "silent": true
  },
  "functions": {
    "api/rewrite.js": {
      "includeFiles": "{patterns/**,profiles/**,core/**,lexicon/**,.patina.default.yaml}"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/playground"
    },
    {
      "source": "/chatgpt.js",
      "destination": "/playground/chatgpt.js"
    },
    {
      "source": "/chatgpt.css",
      "destination": "/playground/chatgpt.css"
    },
    {
      "source": "/rewrite-client.js",
      "destination": "/playground/rewrite-client.js"
    },
    {
      "source": "/analytics.js",
      "destination": "/playground/analytics.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "clipboard-write=(self), camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net; img-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
